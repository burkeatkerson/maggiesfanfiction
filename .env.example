# ============================================================
# Maggie's Fan Fiction — environment variables
# Copy to .env.local and fill in real values. NEVER commit .env.local.
# ============================================================

# Supabase project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase publishable (public) key — safe to expose to the browser. RLS protects
# data. This is the new name for the "anon" key; NEXT_PUBLIC_SUPABASE_ANON_KEY
# also works as a fallback for legacy projects.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Supabase secret key — SERVER ONLY. Bypasses RLS. Used for seeding/admin tasks
# via lib/supabase/admin.ts. New name for the "service_role" key;
# SUPABASE_SERVICE_ROLE_KEY also works. Never expose to the client or commit it.
SUPABASE_SECRET_KEY=

# The single email allowed to sign in (single-author site). Login rejects any
# other address as defense-in-depth on top of RLS.
AUTHOR_EMAIL=

# Public site URL (used later for Open Graph tags + sitemap). e.g. https://maggiesfanfiction.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
